{
  "version": 2,
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/index.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/admin/config.yml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/yaml"
        }
      ]
    }
  ]
}